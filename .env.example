# FurConnect Production Environment Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Django Security Settings
DJANGO_SECRET_KEY=your-strong-secret-key-here
DJANGO_DEBUG=False

# Allowed Hosts (comma-separated)
# Example: yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CSRF Settings (comma-separated URLs)
# Example: https://yourdomain.com,https://www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Cookie Security (production should be True)
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_HTTPONLY=True
DJANGO_SESSION_COOKIE_HTTPONLY=True

# SameSite Cookie Policy (Strict, Lax, or None)
DJANGO_CSRF_COOKIE_SAMESITE=Strict
DJANGO_SESSION_COOKIE_SAMESITE=Strict

# Optional: Database Configuration (if not using SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/furconnect

# Optional: Email Configuration
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
